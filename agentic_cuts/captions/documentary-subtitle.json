{
  "name": "documentary-subtitle",
  "display_name": "Documentary Subtitle",
  "description": "Bottom-aligned subtitle for documentary montages. Small, fades cleanly, doesn't compete with footage.",
  "style_family": "minimal",
  "typography": {
    "family": "Source Serif Pro",
    "weight": 500,
    "italic": false,
    "text_transform": "preserve",
    "size_pct_of_height": 0.034,
    "line_height": 1.3,
    "letter_spacing_em": 0.0
  },
  "colors": {
    "text": "#f0ebe0",
    "background": null,
    "outline": "#0c0c0c",
    "outline_width_px": 2,
    "shadow": "#00000080",
    "shadow_offset_px": [0, 2]
  },
  "position": {
    "y_pct": 0.9,
    "alignment": "center",
    "max_width_pct": 0.7
  },
  "safe_zone": {
    "top_pct": 0.05,
    "bottom_pct": 0.06
  },
  "motion": {
    "type": "fade",
    "duration_ms": 250,
    "easing": "ease_in_out"
  },
  "emphasis": {
    "type": "none"
  },
  "max_words_per_card": 14,
  "tags": ["documentary", "archival", "minimal", "long_form"],
  "contains_emojis": false
}
