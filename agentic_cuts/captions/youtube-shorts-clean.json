{
  "name": "youtube-shorts-clean",
  "display_name": "YouTube Shorts Clean",
  "description": "Slightly smaller than TikTok presets to avoid YT Shorts' tighter UI. Sans-serif, drop shadow, no kinetic noise — built for tutorial and explainer Shorts.",
  "style_family": "kinetic",
  "typography": {
    "family": "Inter",
    "weight": 700,
    "italic": false,
    "text_transform": "preserve",
    "size_pct_of_height": 0.044,
    "line_height": 1.2,
    "letter_spacing_em": 0.0
  },
  "colors": {
    "text": "#ffffff",
    "background": null,
    "outline": "#0c0c0c",
    "outline_width_px": 4,
    "shadow": "#0000007f",
    "shadow_offset_px": [0, 4]
  },
  "position": {
    "y_pct": 0.62,
    "alignment": "center",
    "max_width_pct": 0.85
  },
  "safe_zone": {
    "top_pct": 0.10,
    "bottom_pct": 0.20
  },
  "motion": {
    "type": "fade",
    "duration_ms": 120,
    "easing": "ease_out"
  },
  "emphasis": {
    "type": "color",
    "color": "#ffd200"
  },
  "max_words_per_card": 5,
  "tags": ["youtube", "shorts", "tutorial", "explainer"],
  "contains_emojis": false
}
