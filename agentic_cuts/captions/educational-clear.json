{
  "name": "educational-clear",
  "display_name": "Educational Clear",
  "description": "Maximum legibility for tutorial and explainer content. Generous line height, sentence case, mid-frame placement so the viewer reads with the speaker, not under them.",
  "style_family": "sentence",
  "typography": {
    "family": "Atkinson Hyperlegible",
    "weight": 600,
    "italic": false,
    "text_transform": "sentence",
    "size_pct_of_height": 0.042,
    "line_height": 1.4,
    "letter_spacing_em": 0.0
  },
  "colors": {
    "text": "#ffffff",
    "background": "#0c0c0c99",
    "outline": null,
    "outline_width_px": 0,
    "shadow": null,
    "shadow_offset_px": [0, 0]
  },
  "position": {
    "y_pct": 0.7,
    "alignment": "center",
    "max_width_pct": 0.78
  },
  "safe_zone": {
    "top_pct": 0.08,
    "bottom_pct": 0.12
  },
  "motion": {
    "type": "fade",
    "duration_ms": 180,
    "easing": "ease_out"
  },
  "emphasis": {
    "type": "color",
    "color": "#ffd200"
  },
  "max_words_per_card": 10,
  "tags": ["education", "tutorial", "explainer", "high_legibility"],
  "contains_emojis": false
}
